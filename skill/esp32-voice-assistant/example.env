# Copy to .env and fill in. .env is gitignored.

# STT/TTS provider selection: "xai" | "elevenlabs" — independently switchable,
# any combination works (e.g. xai STT + elevenlabs TTS for a custom voice).
STT_PROVIDER=xai
TTS_PROVIDER=xai

# xAI (required when a provider above is "xai") — https://console.x.ai
XAI_API_KEY=

# ElevenLabs (required only when a provider above is "elevenlabs") — https://elevenlabs.io
ELEVENLABS_API_KEY=
# The voice to speak with — find IDs with: python scripts/elevenlabs_voices.py
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_STT_MODEL=scribe_v1
# PCM rate requested from ElevenLabs. Free/Starter/Creator tiers cap at 24000
# (44100 needs Pro). Audio is resampled locally to TTS_SAMPLE_RATE / the
# device's announcement rate (48000 on the BOX-3), so 24000 is fine.
ELEVENLABS_OUTPUT_RATE=24000

# OpenClaw chat completions endpoint (LAN).
# The chat interface must be ENABLED in OpenClaw for /v1/chat/completions to be served.
OPENCLAW_URL=http://OPENCLAW-IP:18789
# OpenClaw bearer token — required: the endpoint returns 401 without it
OPENCLAW_API_KEY=
# Session key for voice turns (separate from Telegram/HA sessions)
OPENCLAW_SESSION_KEY=agent:main:voice
# How the session key is sent: "user" (OpenAI `user` field) or "header" (X-Session-Key)
OPENCLAW_SESSION_MODE=user
# Model name passed in the chat completions body (OpenClaw may ignore it)
OPENCLAW_MODEL=openclaw
# Max seconds to wait for the agent's reply — tool-heavy turns can run minutes
OPENCLAW_TIMEOUT_SECONDS=240

# xAI TTS voice: ara | eve | leo | rex | sal (or a custom voice_id)
XAI_VOICE=eve
# Spoken language (used by both providers' STT + TTS)
XAI_TTS_LANGUAGE=en
# Sample rate requested from TTS: 8000|16000|22050|24000|44100|48000
TTS_SAMPLE_RATE=24000

# Wyoming servers
WYOMING_HOST=127.0.0.1
WYOMING_PORT=10300
# Phase 1 TTS server (HA integration)
TTS_PORT=10200
# Stream synthesis from xAI (recommended — much faster time-to-first-audio);
# set false to force batch mode
TTS_STREAMING=true

# Phase 2 — ESPHome bridge (direct ESP32, no HA)
# Device IP or .local name, and the `api: encryption: key:` from its ESPHome YAML
ESP32_HOST=
ESP32_NOISE_PSK=
# HTTP port this bridge serves TTS audio on (device fetches from it)
BRIDGE_HTTP_PORT=10400
# LAN IP the device should fetch from; leave empty to autodetect
# (REQUIRED inside Docker — autodetection returns the container IP)
BRIDGE_ADVERTISE_HOST=
# Speaker volume for replies (0-1); leave 0 to keep the device's current volume
BRIDGE_VOLUME=1.0
# Spoken right after your question is transcribed, while the agent works.
# Empty string disables. Synthesized once and cached.
BRIDGE_ACK_PHRASE=On it.
# End-of-speech detection tuning
VAD_THRESHOLD=500
VAD_SILENCE_SECONDS=0.8
VAD_MAX_SECONDS=10

LOG_LEVEL=INFO
